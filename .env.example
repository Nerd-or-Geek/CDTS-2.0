# Reporting system configuration
# Copy to .env and adjust values.

# Required to access admin endpoints (list/export/update reports).
# Change this before deploying anywhere.
ADMIN_TOKEN=change-me

# Where reports are stored (JSON array)
DATA_FILE=backend/data/reports.json

# Where report subjects (people list) are stored
SUBJECTS_FILE=backend/data/subjects.json

# Server bind
HOST=127.0.0.1
PORT=5000

# Set to 1 for live reload / debug tracebacks
DEBUG=1
